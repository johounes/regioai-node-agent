# Modell für den Swarm (ungated – kein HF-Token nötig)
CAG_SWARM_MODEL=NousResearch/Llama-2-7b-hf
# Anzahl Blöcke, die DIESE Node hosten soll. Leer = automatisch nach VRAM.
# Für einen Single-Node-End-to-End-Test alle 32 Blöcke erzwingen: NUM_BLOCKS=32
NUM_BLOCKS=
# Port der Swarm-API, die das Gateway aufruft
SWARM_API_PORT=8077
# DHT-Port des privaten Swarms
DHT_PORT=31337
