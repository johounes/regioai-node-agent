# --- Pflicht ---
CAG_GATEWAY=http://localhost:3000
CAG_NODE_ID=deine-node-id-aus-dem-dashboard
CAG_NODE_KEY=cagnode_dein-key-aus-dem-dashboard
# --- Optional ---
CAG_MODEL=llama3:8b
OLLAMA_URL=http://localhost:11434
PORT=8088
CAG_PUBLIC_URL=http://localhost:8088
HEARTBEAT_INTERVAL=60
CAG_GPU_MEMORY_MB=24576

# --- Ollama-Inferenz-Tuning ---
CAG_NUM_CTX=8192          # Kontextfenster (zu klein → Antworten abgeschnitten)
CAG_NUM_PREDICT=2048      # max. Output-Tokens
CAG_KEEP_ALIVE=30m        # Modell im VRAM halten (kein Reload nach Idle); -1 = dauerhaft

# --- Self-Update (signiert) & Credentials ---
CAG_AUTO_UPDATE=true      # Self-Update an/aus
CAG_UPDATE_URL=           # agent.mjs-Quelle (leer = Public-Repo …/main/agent.mjs)
CAG_MANIFEST_URL=         # signiertes Manifest (leer = …/main/manifest.json)
CAG_UPDATE_HOSTS=         # erlaubte Update-Hosts, kommagetrennt (leer = raw.githubusercontent.com)
CAG_CREDENTIALS_FILE=     # Pfad der Credentials-Datei (Default: ./.node-credentials.json)
