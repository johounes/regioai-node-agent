# --- Pflicht ---
# URL der Plattform (Gateway). Aus Docker heraus: http://host.docker.internal:3000
CAG_GATEWAY=http://localhost:3000
# Leer lassen → der Setup-Assistent (http://localhost:8088) übernimmt die Registrierung.
CAG_NODE_ID=
CAG_NODE_KEY=

# --- Optional ---
# Modell, das dieser Node bedient
CAG_MODEL=llama3:8b
# Ollama-Adresse. Im Docker-Compose: http://ollama:11434
OLLAMA_URL=http://localhost:11434
# Port des Agents
PORT=8088
# Öffentlich/vom Gateway erreichbare URL dieses Agents (wird als endpoint_url gemeldet)
CAG_PUBLIC_URL=http://localhost:8088
# Heartbeat-Intervall in Sekunden
HEARTBEAT_INTERVAL=60
# Fallback-VRAM in MB, falls nvidia-smi nicht verfügbar ist (für blocks_capacity)
CAG_GPU_MEMORY_MB=24576
